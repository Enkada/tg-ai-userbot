# Telegram MTProto API credentials (from https://my.telegram.org)
API_ID=
API_HASH=

# UserBot account phone number (international format, e.g. +1234567890)
PHONE=

# Comma-separated Telegram user IDs allowed to interact with the bot
WHITELIST=

# Path to the SQLite session storage file
SESSION_PATH=data/userbot.session

# Path to the SQLite database (conversation memory)
DB_PATH=data/userbot.db

# Optional proxy for the Telegram (MTProto) connection — only needed where Telegram's data
# centres are blocked at the network level (e.g. a Russian host). Leave blank to connect
# directly. Accepts SOCKS5/HTTP proxy URLs or an MTProxy t.me link:
#   socks5://user:pass@host:port
#   http://user:pass@host:port
#   https://t.me/proxy?server=example.com&port=443&secret=ee...
# The proxy only relays encrypted MTProto; it cannot read message contents.
PROXY_URL=

# Shared generation params (apply to whichever provider is active)
# Legacy persona file, read once to seed the DB (persona lives in persona_versions, edited via /persona).
PERSONA_PROMPT_PATH=prompts/persona.txt
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
# Optional sampling knobs for the CHAT path only (captions/summaries keep their own
# low-temperature settings). Blank = the field is NOT sent at all and the serving
# provider's default applies. Suggested for deepseek/deepseek-v4-flash (non-thinking chat):
#   LLM_TOP_P=0.95             # nucleus cut: trims the junk tail, pins cross-provider behavior
#   LLM_MIN_P=0.02             # sharper tail cut on vLLM-style hosts; ignored where unsupported
#   LLM_PRESENCE_PENALTY=0.4   # curbs DeepSeek's phrase-latching in long chats
#   LLM_FREQUENCY_PENALTY=0.1  # keep mild: high values degrade grammar in inflected languages
LLM_TOP_P=
LLM_MIN_P=
LLM_PRESENCE_PENALTY=
LLM_FREQUENCY_PENALTY=

# Local LLM (OpenAI-compatible llama.cpp server) — the primary backend
LOCAL_LLM_BASE_URL=http://localhost:5001
LOCAL_LLM_MODEL=local

# OpenRouter (https://openrouter.ai) — cloud fallback when the local server is offline.
# Leave OPENROUTER_API_KEY blank to disable. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: shown on OpenRouter's app-ranking leaderboard
OPENROUTER_APP_NAME=tg-ai-userbot
OPENROUTER_APP_URL=
# Upstream provider routing: preferred providers tried first, in order (comma-separated).
# These have the best time-to-first-token for Gemma; blank = OpenRouter's default routing.
OPENROUTER_PROVIDER_ORDER=deepinfra,google-vertex,cloudflare
# Fall back to other providers if the preferred ones are unavailable (true/false).
OPENROUTER_ALLOW_FALLBACKS=true
# Optional ranking for non-listed providers: price | throughput | latency (blank = default).
OPENROUTER_PROVIDER_SORT=

# Optional dedicated OpenRouter vision model for captioning photos when the ACTIVE chat model
# can't see images (e.g. a text-only local model). When the active model already has vision, it
# captions with its own model and this is ignored. Blank = no fallback (photos are dropped when
# the active model is text-only). Requires OPENROUTER_API_KEY. Reuses LLM_CAPTION_* knobs below.
CAPTION_MODEL=
# Caption tuning (used by both the active-model and fallback caption passes):
LLM_CAPTION_MAX_TOKENS=150
LLM_CAPTION_TEMPERATURE=0.3

# Streaming: every reply is delivered as several chat bubbles (split on sentence boundaries)
# instead of one block — closer to how a person texts. Inter-bubble pacing simulates typing
# the next bubble: gap = base + length*perChar, capped at max. Only the idle part is waited
# out (if the previous send took longer, the next goes immediately). Defaults feel like a
# lively, attentive texter.
STREAMING_DELAY_BASE_MS=400
STREAMING_DELAY_PER_CHAR_MS=30
STREAMING_DELAY_MAX_MS=3000

# Human pacing — reads and replies land like a person who isn't glued to the chat.
# Read delay (before the ✓✓ receipt): 0 within READ_DELAY_THRESHOLD minutes of the chat's last
# message (either side — you're both "in the chat"), then rises on a sqrt curve to
# READ_DELAY_MAX seconds at READ_DELAY_FULL_AT minutes of idle, with ±30% jitter. Past ~10 min
# of idle, READ_DELAY_INSTANT_CHANCE rolls a 2-3s read instead ("she had the phone in hand").
# Commands and unsupported message types are always read instantly.
READ_DELAY_THRESHOLD=3
READ_DELAY_MAX=15
READ_DELAY_FULL_AT=130
READ_DELAY_INSTANT_CHANCE=0.15
# Silent beat between the read receipt and the typing indicator: base + chars*perChar ms,
# capped — so the receipt and "typing..." never appear in the same instant. Photos run the
# vision pass inside the beat instead: max(caption pass, 1-2s).
READ_PAUSE_BASE_MS=400
READ_PAUSE_PER_CHAR_MS=25
READ_PAUSE_MAX_MS=2500

# The character name (the {{char}} tag) is not an env var — it defaults to "Sara" and is
# changed live from the chat with /name, stored in the DB so it survives restarts.

# Timezone for the {{period}} tag and the proactive scheduler (IANA name, e.g. Europe/Moscow).
TIMEZONE=Europe/Moscow

# Proactive messaging — the bot initiating conversation on its own. Off by default.
PROACTIVE_ENABLED=false
# Active window (local hours): the bot may only initiate while start <= hour < end.
PROACTIVE_WINDOW_START=7
PROACTIVE_WINDOW_END=23
# The good-morning opener fires once at a random time within this hour range.
PROACTIVE_MORNING_START=7
PROACTIVE_MORNING_END=8
# Base daytime gap (random minutes in range) before the first reach-out after you go quiet.
PROACTIVE_SILENCE_MIN=45
PROACTIVE_SILENCE_MAX=180
# Right-skew exponent for the gap: 1 = uniform, >1 favors shorter gaps with a long tail to MAX.
PROACTIVE_SILENCE_SKEW=2
# Each unanswered reach-out adds this many minutes to the next gap (escalation step)...
PROACTIVE_ESCALATION_STEP=60
# ...up to this many consecutive ignored reach-outs, after which she goes silent until you reply.
PROACTIVE_MAX_IGNORED=8
# How often (ms) the scheduler evaluates each chat.
PROACTIVE_TICK_MS=60000

# Tavily web search (https://app.tavily.com) — AI-native search API for the bot's
# web-search tool. Free tier: 1000 credits/month. Leave blank to disable search.
TAVILY_API_KEY=tvly-dev-REPLACE_ME

# Long-term memory — nightly per-day summaries appended to the system prompt as a "# Memory"
# block (the newest SUMMARY_MAX_KEPT days). Off by default; requires OPENROUTER_API_KEY (summaries
# always run through OpenRouter, independent of the active chat provider).
SUMMARY_ENABLED=false
# Dedicated summarizer model (cheap + faithful). Default below was the best in testing.
SUMMARY_MODEL=google/gemini-2.5-flash-lite
# App-owned summarizer prompt (first-person diary voice).
SUMMARY_PROMPT_PATH=prompts/summary.txt
# A logical day is summarized only when it holds MORE than this many messages.
SUMMARY_MIN_MESSAGES=10
# How many of the newest daily summaries are injected into the system prompt.
SUMMARY_MAX_KEPT=7
# Logical-day boundary (local hour, 0-23): a "day" runs cutoff->cutoff, so a late-night session
# crossing midnight stays in one summary. 3 = 3am.
SUMMARY_CUTOFF_HOUR=3
# How often (ms) the scheduler checks for a completed, un-summarized day. Default 10 min.
SUMMARY_TICK_MS=600000
# Summarizer sampling: low temperature for faithful, non-creative summaries.
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=400
SUMMARY_TIMEOUT_MS=60000

# Long-term memory — durable facts about the user (workplace, people, habits, likes …),
# maintained by a nightly diff pass over each completed day and injected into the system
# prompt as an "# About <user>" block. Curate with /facts, inspect with /prompt f.
# Off by default; requires OPENROUTER_API_KEY. Shares SUMMARY_CUTOFF_HOUR's logical days.
FACTS_ENABLED=false
# Diff-pass model. deepseek/deepseek-v4-flash was the most disciplined merger in testing
# (2026-07-17): gemini-2.5-flash-lite invented op ids, gemini-2.5-flash padded facts with
# one-day details. Runs with reasoning off.
FACTS_MODEL=deepseek/deepseek-v4-flash
# App-owned diff-pass prompt (what counts as a fact + the JSON op format).
FACTS_PROMPT_PATH=prompts/facts.txt
# A day is scanned when it holds MORE than this many messages. Lower than the summary
# threshold on purpose: a 4-message day can still carry "btw, I got the job".
FACTS_MIN_MESSAGES=3
# How often (ms) the scheduler checks for a completed, unscanned day. Default 10 min.
FACTS_TICK_MS=600000
# Diff-pass sampling: low temperature, generous op budget, patient timeout (slow upstreams).
FACTS_TEMPERATURE=0.3
FACTS_MAX_TOKENS=2000
FACTS_TIMEOUT_MS=90000
